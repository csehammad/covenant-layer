flowchart TB
    REG["Register and stake<br/>provider locks collateral"] --> COM["Commit<br/>accept objective, terms bind"]
    COM --> FUL["Fulfill<br/>provider-owned execution"]
    FUL --> EV["Evidence<br/>signed proof artifacts"]
    EV --> VER["Verify<br/>independent integrity check"]
    VER --> SET["Settle on-chain<br/>fulfilled, failed, or disputed"]
    SET --> REP["Reputation<br/>derived from settlement history"]
    REP --> ROUTE["Routing priority<br/>better reputation, more flow"]
    ROUTE --> COM

    SET -->|"failure"| SLASH["Slash<br/>graduated penalty"]
    SLASH -->|"stake reduced"| REG

