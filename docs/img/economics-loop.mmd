flowchart TB
    REG["<b>Register + Stake</b><br/>provider locks collateral"] --> COM["<b>Commit</b><br/>accept objective, terms bind"]
    COM --> FUL["<b>Fulfill</b><br/>provider-owned execution"]
    FUL --> EV["<b>Evidence</b><br/>signed proof artifacts"]
    EV --> VER["<b>Verify</b><br/>independent integrity check"]
    VER --> SET["<b>Settle On-Chain</b><br/>fulfilled · failed · disputed"]
    SET --> REP["<b>Reputation</b><br/>derived from settlement history"]
    REP --> ROUTE["<b>Routing Priority</b><br/>better reputation = more flow"]
    ROUTE --> COM

    SET -->|"failure"| SLASH["<b>Slash</b><br/>graduated penalty"]
    SLASH -->|"stake reduced"| REG

