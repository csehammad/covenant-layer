# Base Sepolia chain-only demo configuration
DEMO_NETWORK=base_sepolia
DEMO_RPC_URL=https://sepolia.base.org
DEMO_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000000

# Wallet/account values
DEMO_AGENT_OWNER=0xAGENT_OWNER
DEMO_PROVIDER_ALPHA_OWNER=0xPROVIDER_ALPHA_OWNER
DEMO_PROVIDER_BRAVO_OWNER=0xPROVIDER_BRAVO_OWNER
DEMO_PROVIDER_CHARLIE_OWNER=0xPROVIDER_CHARLIE_OWNER

# Stakes (as accepted by CLI)
DEMO_STAKE_AGENT=500
DEMO_STAKE_PROVIDER=500

# LLM reasoning model for agent offer comparison (optional)
# If set, the agent uses a reasoning model to analyze and compare offers.
# If not set, falls back to deterministic weighted scoring.
#
# Provider: openai (default) or anthropic
DEMO_LLM_PROVIDER=openai
# Model: o3-mini (default for openai), claude-sonnet-4-20250514 (default for anthropic)
# DEMO_LLM_MODEL=o3-mini
#
# Set your API key:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
